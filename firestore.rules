rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Función auxiliar para verificar si el usuario está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Función para verificar si es admin
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/administradores/$(request.auth.uid));
    }

    // Colección: vendedores
    match /vendedores/{vendorId} {
      // Permitir lectura si:
      // 1. Es el propio documento del usuario
      // 2. Es administrador
      allow read: if isAuthenticated() && (
        request.auth.uid == vendorId || isAdmin()
      );
      
      // Permitir escritura solo si es admin (crear/actualizar vendedores)
      allow write: if isAdmin();
    }

    // Colección: administradores
    match /administradores/{adminId} {
      // Permitir leer tu propio documento de admin
      allow read: if isAuthenticated() && request.auth.uid == adminId;
      
      // Permitir crear/escribir solo si ya eres admin
      allow write: if isAdmin();
    }

    // Colección: viajes
    match /viajes/{viajeId} {
      // Permitir lectura si es tu viaje o eres admin
      allow read: if isAuthenticated() && (
        resource.data.vendedorId == request.auth.uid || isAdmin()
      );
      
      // Permitir creación si el vendedorId coincide con el usuario autenticado o eres admin
      allow create: if isAuthenticated() && (
        request.resource.data.vendedorId == request.auth.uid || isAdmin()
      );
      
      // Permitir actualización si es tu viaje y mantienes el mismo vendedorId, o eres admin
      allow update: if isAuthenticated() && (
        (resource.data.vendedorId == request.auth.uid && 
         request.resource.data.vendedorId == request.auth.uid) || isAdmin()
      );
      
      // Permitir eliminación si es tu viaje o eres admin
      allow delete: if isAuthenticated() && (
        resource.data.vendedorId == request.auth.uid || isAdmin()
      );
    }

    // Colección: gastos
    match /gastos/{gastoId} {
      // Permitir lectura si es tu gasto o eres admin
      allow read: if isAuthenticated() && (
        resource.data.vendedorId == request.auth.uid || isAdmin()
      );
      
      // Permitir creación si el vendedorId coincide con el usuario autenticado o eres admin
      allow create: if isAuthenticated() && (
        request.resource.data.vendedorId == request.auth.uid || isAdmin()
      );
      
      // Permitir actualización si es tu gasto y mantienes el mismo vendedorId, o eres admin
      allow update: if isAuthenticated() && (
        (resource.data.vendedorId == request.auth.uid && 
         request.resource.data.vendedorId == request.auth.uid) || isAdmin()
      );
      
      // Permitir eliminación si es tu gasto o eres admin
      allow delete: if isAuthenticated() && (
        resource.data.vendedorId == request.auth.uid || isAdmin()
      );
    }

    // Colección: app_config
    match /app_config/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
