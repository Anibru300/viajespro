rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLAS TEMPORALES PARA DEBUGGING
    // Estas reglas permiten todo a usuarios autenticados
    // ÚSALAS SOLO PARA DIAGNOSTICAR EL PROBLEMA
    // Después vuelve a las reglas normales
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
