rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Permitir TODO temporalmente para diagnosticar el problema
    // TODO: Restringir después de solucionar
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Reglas específicas para viajespro
    match /viajespro/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
